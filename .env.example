# OnlineCompiler REST API（仅 Serverless 使用，勿提交真实密钥）
# 申请：https://api.onlinecompiler.io/
#
# 本地：复制本文件为 .env
# 联调 CodeRunner（推荐）：npm run api:dev（8787）+ npm run docs:dev（4003）
# 测 Serverless /api：npm run vercel:dev（需在 vercel.json 配置 devCommand，勿单独 docs:build 后 vercel dev）
ONLINECOMPILER_API_KEY=

# CORS 白名单（逗号分隔，不要有空格）
# - 生产站点 + 本地 VitePress（npm run docs:dev 默认 4003 端口）
# - 若浏览器地址栏是 127.0.0.1，可再加 http://127.0.0.1:4003
# Vercel 线上请在 Dashboard 只配置生产域名，不要带 localhost
CODE_RUNNER_CORS_ORIGINS=https://physics.matsubarasoda.com,http://localhost:4003
