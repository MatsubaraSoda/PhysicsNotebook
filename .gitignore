node_modules/

# VitePress 构建输出目录
docs/.vitepress/dist/

# 本地缓存文件
docs/.vitepress/cache/

# Vercel 的构建输出缓存
.vercel/output/

# ============================================
# 日志文件
# ============================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# 操作系统文件
# ============================================
.DS_Store
Thumbs.db

# ============================================
# 编辑器配置
# ============================================
