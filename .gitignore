.vscode/*
!.vscode/extensions.json
.idea
.cursor/

# 其他编辑器文件
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================
# 构建和缓存文件
# ============================================
*.tsbuildinfo
.eslintcache
*.local

# 本地 / Vercel 密钥（勿提交）
.env
.env.local
.env.*.local

# ============================================
# 本地私有内容（不入库）
# ============================================
# apps/electromagnetic-theory 及其构建产物（docs/public/apps 等）
# playground、pdf、tmp
# 化学 / 日语笔记及 public 静态资源
